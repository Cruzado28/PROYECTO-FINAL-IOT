diff --git a/public/assets/js/camera-monitor.js b/public/assets/js/camera-monitor.js
new file mode 100644
index 0000000..cfb0f12
--- /dev/null
+++ b/public/assets/js/camera-monitor.js
@@ -0,0 +1,701 @@
+// ============================================================
+// MONITOREO POR ESP32-CAM + DETECCION DE ESPACIOS
+// Este módulo es independiente del cobro RFID.
+// El tiempo de estacionamiento sigue calculándose desde ENTRADA RFID
+// hasta SALIDA RFID. La cámara solo indica qué espacio está ocupado.
+// ============================================================
+(function () {
+  const TOTAL_ESPACIOS = 10;
+
+  const cam = window.smartparkCamera = {
+    mode: localStorage.getItem('smartpark_camera_mode') || 'prueba',
+    serverUrl: localStorage.getItem('smartpark_camera_server') || '',
+    cameraUrl: localStorage.getItem('smartpark_camera_url') || '',
+    connected: false,
+    zonas: [],
+    ocupacion: {},
+    puntosActuales: [],
+    modoNuevaZona: false,
+    numeroPendiente: null,
+    zonaEditando: null,
+    zonaDebugActual: null,
+    intervalFrame: null,
+    intervalEstado: null,
+    intervalDebug: null,
+    lastFrameStart: 0,
+    ultimaLectura: null,
+    ultimaLatencia: 0
+  };
+
+  function el(id) {
+    return document.getElementById(id);
+  }
+
+  function toast(tipo, mensaje, icono) {
+    if (typeof showToast === 'function') {
+      showToast(tipo, mensaje, icono || 'fa-circle-info');
+    } else {
+      console.log(`[${tipo}] ${mensaje}`);
+    }
+  }
+
+  function normalizarUrl(valor, usarHttp = true) {
+    let url = String(valor || '').trim();
+    if (!url) return '';
+    url = url.replace(/\/$/, '');
+    if (!/^https?:\/\//i.test(url) && usarHttp) {
+      url = 'http://' + url;
+    }
+    return url;
+  }
+
